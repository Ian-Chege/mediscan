{
  "expo": {
    "name": "MediScan",
    "slug": "mediscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mediscan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90D9"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "MediScan needs camera access to scan prescriptions.",
        "NSPhotoLibraryUsageDescription": "MediScan needs photo library access to select prescription images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4A90D9"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4A90D9"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MediScan needs photo access to select prescription images.",
          "cameraPermission": "MediScan needs camera access to scan prescriptions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
