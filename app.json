{
  "expo": {
    "name": "DrugScan",
    "slug": "mediscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mediscan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90D9"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DrugScan needs camera access to scan prescriptions.",
        "NSPhotoLibraryUsageDescription": "DrugScan needs photo library access to select prescription images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.ianoviewcy.mediscan"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4A90D9"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ianoviewcy.mediscan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4A90D9"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DrugScan needs photo access to select prescription images.",
          "cameraPermission": "DrugScan needs camera access to scan prescriptions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2fc83746-ec89-4e19-b46c-17fbe738e6f8"
      }
    }
  }
}
